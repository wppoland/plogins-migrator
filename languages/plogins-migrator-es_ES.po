#: templates/admin-page.php:39
msgid "Database"
msgstr "Base de datos"

#: templates/admin-page.php:40
msgid "Spam comments"
msgstr "Comentarios no deseados"

#: templates/admin-page.php:41
msgid "Post revisions"
msgstr "Publicar revisiones"

#: templates/admin-page.php:42
msgid "Transients"
msgstr "Transitorios"

