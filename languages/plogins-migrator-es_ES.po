#: src/Engine/Import/Preflight.php:108
msgid "PHP version"
msgstr "versión PHP"

#. translators: 1: source PHP, 2: this PHP
#: src/Engine/Import/Preflight.php:111
#, php-format
msgid ""
"Backup was made on PHP %1$s; this server runs %2$s. Code relying on newer "
"PHP may not run here."
msgstr ""
"La copia de seguridad se realizó en PHP %1$s; este servidor ejecuta %2$s. Es"
" posible que el código que se basa en PHP más reciente no se ejecute aquí."

