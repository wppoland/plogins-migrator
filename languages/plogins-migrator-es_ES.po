#. Plugin Name of the plugin
#: plogins-migrator.php src/Admin/Page.php:52 templates/admin-page.php:13
msgid "Migrator"
msgstr "Migrator"

#. Plugin URI of the plugin
#: plogins-migrator.php
msgid "https://plogins.com/migrator/"
msgstr "https://plogins.com/es/migrator/"

#. Description of the plugin
#: plogins-migrator.php
msgid ""
"Back up, clone and migrate your WordPress site to a new host. One file, drag"
" and drop, no technical setup."
msgstr ""
"Haga una copia de seguridad, clone y migre tu sitio de WordPress a un nuevo "
"host. Un archivo, arrastrar y soltar, sin configuración técnica."

#. Author of the plugin
#: plogins-migrator.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: plogins-migrator.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

