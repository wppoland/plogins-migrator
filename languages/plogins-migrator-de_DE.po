#. Plugin Name of the plugin
#: plogins-migrator.php
msgid "Plogins Migrator - Site Migration and Backup"
msgstr "Plogins Migrator - Site-Migration und Backup"

#. Plugin URI of the plugin
#: plogins-migrator.php
msgid "https://plogins.com/plogins-migrator/"
msgstr "https://plogins.com/de/plogins-migrator/"

#. Description of the plugin
#: plogins-migrator.php
msgid ""
"Back up, clone and migrate your WordPress site to a new host. One file, drag"
" and drop, no technical setup."
msgstr ""
"Sichern, klonen und migriere deine WordPress-Site auf einen neuen Host. Eine"
" Datei, Drag-and-Drop, keine technische Einrichtung."

#. Author of the plugin
#: plogins-migrator.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
