#. translators: 1: source prefix, 2: this site's prefix
#: src/Engine/Import/Preflight.php:41
#, php-format
msgid ""
"Archive uses \"%1$s\" but this site uses \"%2$s\". The restore will be "
"refused until this site's $table_prefix in wp-config.php matches."
msgstr ""
"Das Archiv verwendet „%1$s“, aber diese Site verwendet „%2$s“. Die "
"Wiederherstellung wird abgelehnt, bis das $table_prefix dieser Site in wp-"
"config.php übereinstimmt."

#. translators: %s: table prefix
#: src/Engine/Import/Preflight.php:50
#, php-format
msgid "Matches (%s)."
msgstr "Übereinstimmungen (%s)."

#: src/Engine/Import/Preflight.php:60
msgid ""
"This archive or this site is a network. A network-to-network restore needs "
"Migrator Pro; the free edition will refuse it."
msgstr ""
"Dieses Archiv oder diese Site ist ein Netzwerk. Für eine Netzwerk-zu-"
"Netzwerk-Wiederherstellung ist Migrator Pro erforderlich. Die kostenlose "
"Edition wird dies ablehnen."

#: src/Engine/Import/Preflight.php:76 src/Engine/Import/Preflight.php:87
msgid "Disk space"
msgstr "Speicherplatz"

#. translators: 1: free space, 2: estimated needed
#: src/Engine/Import/Preflight.php:79
#, php-format
msgid ""
"About %1$s free, restore may need ~%2$s. Free up space before restoring."
msgstr ""
"Ungefähr %1$s kostenlos, für die Wiederherstellung ist möglicherweise ~%2$s "
"erforderlich. Gib vor der Wiederherstellung Speicherplatz frei."

#. translators: %s: free space
#: src/Engine/Import/Preflight.php:88
#, php-format
msgid "%s free."
msgstr "%s kostenlos."

#: src/Engine/Import/Preflight.php:97
msgid "Writable files"
msgstr "Beschreibbare Dateien"

#: src/Engine/Import/Preflight.php:98
msgid "wp-content is not writable by the web server. File restore will fail."
msgstr ""
"wp-content ist vom Webserver nicht beschreibbar. Die Dateiwiederherstellung "
"schlägt fehl."

#: src/Engine/Import/Preflight.php:108
msgid "PHP version"
msgstr "PHP-Version"

#. translators: 1: source PHP, 2: this PHP
#: src/Engine/Import/Preflight.php:111
#, php-format
msgid ""
"Backup was made on PHP %1$s; this server runs %2$s. Code relying on newer "
"PHP may not run here."
msgstr ""
"Das Backup wurde auf PHP %1$s erstellt; Auf diesem Server wird %2$s "
"ausgeführt. Code, der auf neuerem PHP basiert, kann hier möglicherweise "
"nicht ausgeführt werden."

