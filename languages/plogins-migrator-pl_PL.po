msgid "None (fastest, largest file)"
msgstr "Brak (najszybszy, największy plik)"

#: templates/admin-page.php:113
msgid "GZip (smaller file, a little slower)"
msgstr "GZip (mniejszy plik, trochę wolniejszy)"

#: templates/admin-page.php:126
msgid "Create backup"
msgstr "Utwórz kopię zapasową"

#: templates/admin-page.php:136
