#. Plugin Name of the plugin
#: plogins-migrator.php src/Admin/Page.php:52 templates/admin-page.php:13
msgid "Migrator"
msgstr "Migrator"

#. Plugin URI of the plugin
#: plogins-migrator.php
msgid "https://plogins.com/migrator/"
msgstr "https://plogins.com/pl/migrator/"

#. Description of the plugin
#: plogins-migrator.php
msgid ""
"Back up, clone and migrate your WordPress site to a new host. One file, drag"
" and drop, no technical setup."
msgstr ""
"Utwórz kopię zapasową, sklonuj i przenieś swoją witrynę WordPress na nowy "
"host. Jeden plik, przeciągnij i upuść, bez konfiguracji technicznej."

#. Author of the plugin
#: plogins-migrator.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: plogins-migrator.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#. translators: 1: Required PHP version, 2: Current PHP version
#: plogins-migrator.php:41
#, php-format
msgid "Migrator requires PHP %1$s or higher. You are running PHP %2$s."
msgstr "Migrator wymaga PHP %1$s lub nowszego. Używasz PHP %2$s."

