#. Plugin Name of the plugin
#: plogins-migrator.php
msgid "Plogins Migrator - Site Migration and Backup"
msgstr "Plogins Migrator - migracja witryny i tworzenie kopii zapasowych"

#. Plugin URI of the plugin
#: plogins-migrator.php
msgid "https://plogins.com/plogins-migrator/"
msgstr "https://plogins.com/pl/plogins-migrator/"

#. Description of the plugin
#: plogins-migrator.php
msgid ""
"Back up, clone and migrate your WordPress site to a new host. One file, drag"
" and drop, no technical setup."
msgstr ""
"Utwórz kopię zapasową, sklonuj i przenieś swoją witrynę WordPress na nowy "
"host. Jeden plik, przeciągnij i upuść, bez konfiguracji technicznej."

#. Author of the plugin
#: plogins-migrator.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: plogins-migrator.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

