# wp.org Stable Readme translation (pl_PL)
msgid ""
msgstr ""
"Project-Id-Version: migrator Stable Readme\n"
"Last-Translator: wppoland.com <hello@wppoland.com>\n"
"Language-Team: Polish <pl@li.org>\n"
"Language: pl\n"
"MIME-Version: 1.0\n"
